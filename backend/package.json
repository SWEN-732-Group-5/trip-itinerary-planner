{
	"name": "backend",
	"version": "1.0.0",
	"description": "",
	"main": "src/main.py",
	"scripts": {
		"prepare": "uv sync",
		"uv": "uv",
		"dev": "concurrently \"npm run dev:uv\" \"npm run dev:db\"",
		"dev:uv": "uv run dev",
		"dev:db": "./db.sh",
		"main": "uv run main",
		"db": "./db.sh",
		"db:status": "docker compose ps",
		"db:up": "docker compose up",
		"db:down": "docker compose down",
		"test": "uv run -m pytest --cov --cov-branch --cov-report=xml"
	},
	"keywords": [],
